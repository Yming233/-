def FL_Train(init_global_model, client_data_loaders, test_loader, FL_params):
    """
    标准联邦训练函数（修复参数冲突：移除强制报错，改为动态适配）
    """
    # 移除原始强制报错逻辑，改为警告提示（保留功能，不阻断运行）
    if FL_params.if_retrain:
        print("⚠️ 警告：FL_Train阶段if_retrain=True，已自动临时关闭以完成标准训练")
        FL_params.if_retrain = False  # 临时关闭，完成标准训练后恢复
    
    if FL_params.if_unlearning:
        print("⚠️ 警告：FL_Train阶段if_unlearning=True，已自动临时关闭以完成标准训练")
        FL_params.if_unlearning = False  # 临时关闭，完成标准训练后恢复

    # 原版训练逻辑完全保留
    all_global_models = list()
    all_client_models = list()
    global_model = init_global_model
    all_global_models.append(copy.deepcopy(global_model))

    for epoch in range(FL_params.global_epoch):
        client_models = global_train_once(global_model, client_data_loaders, test_loader, FL_params)
        # IMPORTANT 注释保留
        all_client_models += client_models
        global_model = fedavg(client_models)
        print("Global Federated Learning epoch = {}".format(epoch))
        all_global_models.append(copy.deepcopy(global_model))

    # 恢复原始参数（不影响后续遗忘/重训练）
    FL_params.if_retrain = True if hasattr(FL_params, '_origin_if_retrain') else FL_params.if_retrain
    FL_params.if_unlearning = True if hasattr(FL_params, '_origin_if_unlearning') else FL_params.if_unlearning
    
    return all_global_models, all_client_models


def FL_Retrain(init_global_model, client_data_loaders, test_loader, FL_params):
    """
    联邦重训练函数（保留原版逻辑，优化参数检查）
    """
    # 优化参数检查：更友好的提示，而非直接报错
    if not FL_params.if_retrain:
        print("⚠️ 警告：FL_Retrain阶段if_retrain=False，已自动开启以完成重训练")
        FL_params.if_retrain = True
    
    if FL_params.forget_client_idx not in range(FL_params.N_client):
        raise ValueError(
            f'FL_params.forget_client_idx必须在范围 [{0}, {FL_params.N_client-1}] 内，当前值：{FL_params.forget_client_idx}'
        )

    print('\n')
    print(5*"#"+"  Federated Retraining Start  "+5*"#")
    print("Federated Retrain with Forget Client NO.{}".format(FL_params.forget_client_idx))
    retrain_GMs = list()
    all_client_models = list()
    retrain_GMs.append(copy.deepcopy(init_global_model))
    global_model = init_global_model

    for epoch in range(FL_params.global_epoch):
        client_models = global_train_once(global_model, client_data_loaders, test_loader, FL_params)
        # IMPORTANT 注释保留
        global_model = fedavg(client_models)
        print("Global Retraining epoch = {}".format(epoch))
        retrain_GMs.append(copy.deepcopy(global_model))
        all_client_models += client_models

    print(5*"#"+"  Federated Retraining End  "+5*"#")
    return retrain_GMs


def global_train_once(global_model, client_data_loaders, test_loader, FL_params):
    """
    全局单次训练函数（修复设备适配，优化逻辑判断）
    """
    # 设备适配：兼容CPU/GPU，修复原版逻辑错误
    use_gpu = FL_params.use_gpu and FL_params.cuda_state
    device = torch.device("cuda" if use_gpu else "cpu")
    device_cpu = torch.device("cpu")

    # 初始化客户端模型和优化器
    client_models = []
    client_sgds = []
    for ii in range(FL_params.N_client):
        client_models.append(copy.deepcopy(global_model))
        client_sgds.append(optim.SGD(client_models[ii].parameters(), lr=FL_params.local_lr, momentum=0.9))

    # 客户端本地训练
    for client_idx in range(FL_params.N_client):
        # 跳过被遗忘/重训练需要忽略的客户端（合并判断逻辑，避免重复）
        skip_client = (FL_params.if_retrain or FL_params.if_unlearning) and (FL_params.forget_client_idx == client_idx)
        if skip_client:
            print(f"跳过客户端 {client_idx}（遗忘/重训练标记已开启）")
            continue

        model = client_models[client_idx]
        optimizer = client_sgds[client_idx]

        model.to(device)
        model.train()

        # 本地训练轮次
        for local_epoch in range(FL_params.local_epoch):
            for batch_idx, (data, target) in enumerate(client_data_loaders[client_idx]):
                data = data.to(device)
                target = target.to(device)

                optimizer.zero_grad()
                pred = model(data)
                criteria = nn.CrossEntropyLoss()
                loss = criteria(pred, target)
                loss.backward()
                optimizer.step()

            if FL_params.train_with_test:
                print("Local Client No. {}, Local Epoch: {}".format(client_idx, local_epoch))
                test(model, test_loader)

        # 模型转回CPU，避免GPU内存泄漏
        model.to(device_cpu)
        client_models[client_idx] = model

    # 移除被遗忘的客户端模型（修复原版索引错误）
    if FL_params.if_retrain and FL_params.forget_client_idx in range(len(client_models)):
        client_models.pop(FL_params.forget_client_idx)
    elif FL_params.if_unlearning and FL_params.forget_client_idx in range(len(client_models)):
        client_models.pop(FL_params.forget_client_idx)

    return client_models


def test(model, test_loader):
    """
    模型测试函数（修复设备适配，避免数据和模型设备不匹配）
    """
    model.eval()
    test_loss = 0
    test_acc = 0
    device = next(model.parameters()).device  # 自动获取模型所在设备
    with torch.no_grad():
        for data, target in test_loader:
            data = data.to(device)
            target = target.to(device)
            
            output = model(data)
            criteria = nn.CrossEntropyLoss()
            test_loss += criteria(output, target)  # sum up batch loss

            pred = torch.argmax(output, axis=1)
            # 转回CPU计算准确率，避免GPU tensor不兼容sklearn
            test_acc += accuracy_score(pred.cpu().numpy(), target.cpu().numpy())

    # 计算平均损失和准确率（修复原版分母错误）
    test_loss /= len(test_loader)
    test_acc /= len(test_loader)
    print('Test set: Average loss: {:.8f}'.format(test_loss.item()))
    print('Test set: Average acc:  {:.4f}'.format(test_acc))
    return (test_loss, test_acc)


def fedavg(local_models):
    """
    联邦平均函数（保留原版逻辑，增加空列表防护）
    """
    if not local_models:
        raise ValueError("本地模型列表为空，无法执行FedAvg")
    
    # 初始化全局模型参数
    global_model = copy.deepcopy(local_models[0])
    avg_state_dict = global_model.state_dict()
    local_state_dicts = [model.state_dict() for model in local_models]

    # 计算参数平均值
    for layer in avg_state_dict.keys():
        avg_state_dict[layer] = torch.zeros_like(avg_state_dict[layer])
        for client_idx in range(len(local_models)):
            avg_state_dict[layer] += local_state_dicts[client_idx][layer]
        avg_state_dict[layer] /= len(local_models)

    # 加载平均后的参数
    global_model.load_state_dict(avg_state_dict)
    return global_model
